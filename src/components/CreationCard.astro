---
interface Props {
  title: string;
  image: string;
  type: string;
  description?: string;
  likes: number;
  slug: string;
}

const TYPE_LABELS: Record<string, string> = {
  flyer: "Flyer",
  brochure: "Brochure",
  affiche: "Affiche",
  packaging: "Packaging",
  identite: "Identité",
  logo: "Logo",
  web: "Web",
  autre: "Autre",
};

const { title, image, type, description, likes, slug } = Astro.props;
const typeLabel = TYPE_LABELS[type] ?? type;
---

<a href={`/creations/${slug}`} class="card">
  <div class="card-image-wrap">
    <img src={image} alt={title} loading="lazy" />
    <span class="card-type-badge">{typeLabel}</span>
  </div>
  <div class="card-body">
    <h3>{title}</h3>
    {description && <p>{description}</p>}
  </div>
  <div class="card-footer">
    <button
      class="like-btn"
      data-slug={slug}
      data-base-likes={likes}
      aria-label="Aimer cette création"
      onclick="event.preventDefault(); event.stopPropagation();"
    >
      <svg class="like-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <span class="like-count">{likes}</span>
    </button>
  </div>
</a>
